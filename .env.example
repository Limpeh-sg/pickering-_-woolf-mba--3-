# Frontend Configuration
VITE_APP_NAME="Pickering Global Campus Master of Business Administration"
VITE_API_URL="http://localhost:3001"

# Form Email Configuration
# Static fallback: forms open the user's email client and send to this recipient.
VITE_FORM_RECIPIENT_EMAIL="admissions@pickering.education"

# Optional production endpoint: set this to a server, Formspree, Make/Zapier webhook,
# or custom API route that accepts POST JSON form payloads.
VITE_FORM_ENDPOINT=""

# Local database file for leads. One JSON object is appended per line.
DATABASE_DIR="./data"
LEADS_FILE="./data/leads.jsonl"

# Lark / Feishu custom bot webhook — used directly by the browser (no backend needed).
# All forms (homepage + /apply /consult /brochure) send here first; mailto is fallback.
# Get URL from: Lark > Bot > Custom Bot > Webhook URL
VITE_LARK_WEBHOOK_URL=""

# Backend-only Lark webhook (only used if running the Express backend server).
LARK_WEBHOOK_URL=""

# Optional social media URLs. Empty values are hidden automatically.
VITE_SOCIAL_LINKEDIN_URL=""
VITE_SOCIAL_INSTAGRAM_URL=""
VITE_SOCIAL_FACEBOOK_URL=""
VITE_SOCIAL_XIAOHONGSHU_URL=""
VITE_SOCIAL_YOUTUBE_URL=""

# Outlook / Microsoft 365 SMTP settings for backend email notifications.
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="admissions@pickering.education"
SMTP_PASS="your_outlook_app_password_or_smtp_password_here"
FROM_EMAIL="admissions@pickering.education"
ADMIN_EMAIL="admissions@pickering.education"

# Backend Configuration
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
